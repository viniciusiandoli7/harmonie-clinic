generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Patient {
  id               String                  @id @default(uuid())
  name             String
  email            String?                 @unique
  phone            String?
  birthDate        DateTime?
  notes            String?
  isActive         Boolean                 @default(true)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @default(now()) @updatedAt

  appointments     Appointment[]
  consentDocuments PatientConsentDocument[]
  contracts        PatientContract[]
  evolutionPlans   ClinicalEvolutionPlan[]
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELED
}

enum PaymentStatus {
  PENDING
  PAID
  CANCELED
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum Room {
  A
  B
}

enum ConsentDocumentStatus {
  PENDING
  SIGNED
  CANCELED
}

enum ContractStatus {
  PENDING
  SIGNED
  CANCELED
}

enum ContractPaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  PIX
  CASH
  BANK_SLIP
  BANK_TRANSFER
  OTHER
}

enum ClinicalEvolutionPlanStatus {
  ACTIVE
  FINISHED
  CANCELED
}

model Appointment {
  id              String            @id @default(uuid())
  date            DateTime
  status          AppointmentStatus @default(SCHEDULED)
  durationMinutes Int               @default(30)
  notes           String?
  procedureName   String?
  price           Float?
  paymentStatus   PaymentStatus     @default(PENDING)
  room            Room              @default(A)

  patientId       String
  patient         Patient           @relation(fields: [patientId], references: [id])

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @default(now()) @updatedAt

  @@index([date])
  @@index([patientId])
}

model BlockedTime {
  id        String   @id @default(uuid())
  start     DateTime
  end       DateTime
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([start, end])
}

model FinancialTransaction {
  id                    String          @id @default(uuid())
  date                  DateTime
  description           String
  category              String
  amount                Float
  type                  TransactionType

  grossAmount           Float?
  receivedAmount        Float?
  pendingAmount         Float?
  clinicCommissionPct   Float?
  clinicCommissionValue Float?
  professionalValue     Float?
  operationalCost       Float?
  clinicProfit          Float?

  notes                 String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @default(now()) @updatedAt

  @@index([date])
}

model TreatmentConsentTemplate {
  id            String   @id @default(uuid())
  treatmentName String   @unique
  title         String
  content       String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
}

model PatientConsentDocument {
  id            String                @id @default(uuid())
  token         String                @unique
  patientId     String
  patient       Patient               @relation(fields: [patientId], references: [id])
  treatmentName String
  title         String
  content       String
  status        ConsentDocumentStatus @default(PENDING)
  signedAt      DateTime?
  signatureName String?
  signatureIp   String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @default(now()) @updatedAt

  @@index([patientId])
  @@index([token])
}

model PatientContract {
  id               String                @id @default(uuid())
  token            String                @unique
  patientId        String
  patient          Patient               @relation(fields: [patientId], references: [id])

  title            String
  content          String

  subtotal         Float                 @default(0)
  discount         Float                 @default(0)
  total            Float                 @default(0)

  paymentMethod    ContractPaymentMethod @default(OTHER)
  paymentDetails   String?

  itemsJson        Json
  status           ContractStatus        @default(PENDING)

  signedAt         DateTime?
  signatureName    String?
  signatureIp      String?

  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @default(now()) @updatedAt

  @@index([patientId])
  @@index([token])
}

model ClinicalEvolutionPlan {
  id                String                      @id @default(uuid())
  patientId         String
  patient           Patient                     @relation(fields: [patientId], references: [id])

  treatmentName     String
  packageName       String?
  totalSessions     Int                         @default(1)
  completedSessions Int                         @default(0)
  status            ClinicalEvolutionPlanStatus @default(ACTIVE)

  startDate         DateTime?
  endDate           DateTime?
  goals             String?
  notes             String?

  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @default(now()) @updatedAt

  sessions          ClinicalEvolutionSession[]

  @@index([patientId])
}

model ClinicalEvolutionSession {
  id                   String                @id @default(uuid())
  planId               String
  plan                 ClinicalEvolutionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  sessionNumber        Int
  sessionDate          DateTime              @default(now())
  performedProcedure   String?
  bodyMeasurements     String?
  clinicalNotes        String?
  patientSignatureName String?
  signedAt             DateTime?
  imagesJson           Json?

  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @default(now()) @updatedAt

  @@index([planId])
}