// -----------------------------------------
// CONFIGURAÇÃO DO CLIENTE E BANCO
// -----------------------------------------

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------
// MODELOS PRINCIPAIS
// -----------------------------------------

model Patient {
  id                String    @id @default(uuid())
  name              String
  email             String?   @unique
  phone             String?
  createdAt         DateTime  @default(now())
  birthDate         DateTime?
  
  // 'notes' armazena a "Observação Crítica" que aparece no Insight Clínico
  notes             String?   
  
  updatedAt         DateTime  @default(now()) @updatedAt
  isActive          Boolean   @default(true)
  
  // Endereço e Documentos
  address           String?
  addressComplement String?
  addressNumber     String?
  neighborhood      String?
  city              String?
  state             String?
  zipCode           String?
  cpf               String?   @unique
  rg                String?
  
  // Relacionamento e CRM
  crmSource         String?   // Ex: Instagram, Indicação, Google
  referralName      String?   // Nome de quem indicou
  crmStatus         String?   @default("Novo Lead") // Novo Lead, Avaliação, Procedimento, Retorno, VIP
  imageAuthorized   Boolean   @default(false)
  interestProcedure String?   // Procedimento de maior interesse
  patientProfile    String?   // Conservadora, VIP, foco pele, sensível a preço etc.
  commercialNotes   String?   @db.Text
  conversionStatus  String?   // Fechou no dia, vai pensar, achou caro etc.
  proposedValue     Float?
  closedValue       Float?
  lostReason        String?
  firstEvaluationAt DateTime?
  nextSuggestedAt   DateTime?
  
  // Relacionamentos (Lado Inverso)
  appointments      Appointment[]
  evolutionPlans    ClinicalEvolutionPlan[]
  evolutions        ClinicalEvolution[]
  anamnesis         PatientAnamnesis?
  consentDocuments  PatientConsentDocument[]
  contracts         PatientContract[]
  sales             Sale[]
  medicalRecords    MedicalRecord[] 
  transactions      FinancialTransaction[]
  installments      FinancialInstallment[]
  inventoryMovements InventoryMovement[]
  photos            PatientPhoto[]
  treatmentPlans    TreatmentPlan[]
  structuredEvolutions StructuredClinicalEvolution[]
  postProcedureTasks PostProcedureTask[]
  evaluationConversions EvaluationConversion[]

  // ÍNDICES: Para buscas instantâneas por nome, CPF ou Telefone
  @@index([name])
  @@index([cpf])
  @@index([phone])
}

model Appointment {
  id              String            @id @default(uuid())
  date            DateTime
  patientId       String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @default(now()) @updatedAt
  
  status          AppointmentStatus @default(SCHEDULED)
  durationMinutes Int               @default(30)
  procedureName   String?           // Nome do serviço (Ex: Lavieen)
  price           Float?
  paymentStatus   PaymentStatus     @default(PENDING)
  
  room            Room              @default(A)
  notes           String?           // Notas específicas desta sessão
  
  patient         Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)

  // ÍNDICES: Para carregar a agenda e o histórico do paciente rapidamente
  @@index([date])
  @@index([patientId])
}

// -----------------------------------------
// GESTÃO CLÍNICA E PRONTUÁRIO
// -----------------------------------------

model ClinicalEvolution {
  id        String   @id @default(uuid())
  patientId String
  content   String   @db.Text
  type      String   @default("MANUAL") // MANUAL, SALE_RECORD, SYSTEM
  important Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
}

model MedicalRecord {
  id        String   @id @default(uuid())
  patientId String
  type      String   // Ex: "TERMO ULTRASSOM", "AVALIAÇÃO FACIAL"
  content   Json     // Salva o texto editado ou estrutura do termo
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
}

model PatientAnamnesis {
  id                       String   @id @default(uuid())
  patientId                String   @unique
  
  profession               String?
  sunExposure              Boolean  @default(false)
  mainComplaint            String?
  
  // Campos da Anamnese
  previousFillers          String?
  previousBotox            String?
  takingRoacutan           Boolean  @default(false)
  medications              String?
  allergicToEgg            Boolean  @default(false)
  allergicToSeafood        String?
  dentalAnesthesia         Boolean  @default(false)
  dentalAnesthesiaReaction Boolean  @default(false)
  procedureReaction        String?
  keloidTendency           Boolean  @default(false)
  degenerativeDisease      String?
  diseases                 String?
  allergies                String?
  hasHerpes                Boolean  @default(false)
  bloodPressure            String?  // ALTA, NORMAL, BAIXA
  pregnantOrNursing        Boolean  @default(false)
  previousPregnancies      Boolean  @default(false)
  exercises                Boolean  @default(false)
  skinCareRoutine          String?
  weightLoss               String?  // +5kg, +10kg, +20kg, +40kg, nao
  intendsToLoseWeight      String?
  intendsSurgery           String?
  surgeries                String?
  recentTreatmentOrVaccine String?
  permanentImplants        String?
  consentSigned            Boolean  @default(false)
  
  // 👇 NOVOS CAMPOS ADICIONADOS AQUI 👇
  usesAspirin              Boolean  @default(false)
  usesCorticosteroids      Boolean  @default(false)
  smoker                   Boolean  @default(false)
  drinksAlcohol            Boolean  @default(false)
  usesAnticoagulant        Boolean  @default(false)
  hasAutoimmuneDisease     Boolean  @default(false)
  hasDiabetes              Boolean  @default(false)
  hasEpilepsy              Boolean  @default(false)
  activeInfection          Boolean  @default(false)
  recentDentalProcedure    Boolean  @default(false)
  fillerComplicationHistory String?
  clinicalRiskNotes        String?  @db.Text
  
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  patient                  Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
}

model ClinicalEvolutionPlan {
  id                String                      @id @default(uuid())
  patientId         String
  treatmentName     String
  packageName       String?
  totalSessions     Int                         @default(1)
  completedSessions Int                         @default(0)
  status            ClinicalEvolutionPlanStatus @default(ACTIVE)
  startDate         DateTime?
  endDate           DateTime?
  goals             String?
  notes             String?
  
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @default(now()) @updatedAt
  patient           Patient                     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  sessions          ClinicalEvolutionSession[]

  @@index([patientId])
}

model ClinicalEvolutionSession {
  id                   String                @id @default(uuid())
  planId               String
  sessionNumber        Int
  sessionDate          DateTime              @default(now())
  performedProcedure   String?
  
  bodyMeasurements     String?               @db.Text 
  
  clinicalNotes        String?
  imagesJson           Json?                 // Fotos de antes e depois
  patientSignatureName String?
  signedAt             DateTime?
  
  // Desenho da assinatura na evolução
  signatureImage       String?               @db.Text 
  
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @default(now()) @updatedAt
  plan                 ClinicalEvolutionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
}

// -----------------------------------------
// FINANCEIRO E VENDAS
// -----------------------------------------

model Sale {
  id             String                @id @default(uuid())
  patientId      String
  professionalId String
  serviceId      String
  
  price          Float
  discount       Float                 @default(0)
  finalPrice     Float                 @default(0)
  
  payments       SalePayment[] 
  transactions   FinancialTransaction[]
  installments   FinancialInstallment[]
  
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @default(now()) @updatedAt
  
  patient        Patient               @relation(fields: [patientId], references: [id])
  professional   Professional          @relation(fields: [professionalId], references: [id])
  service        Treatment             @relation(fields: [serviceId], references: [id])
  saleItems      SaleItem[]

  // ÍNDICES: Para gerar relatórios financeiros por paciente ou data
  @@index([patientId])
  @@index([createdAt])
  @@index([professionalId])
}

model SalePayment {
  id        String                @id @default(uuid())
  saleId    String
  amount    Float                 // O valor pago
  method    ContractPaymentMethod // Forma de pagamento
  
  createdAt DateTime              @default(now())
  
  sale      Sale                  @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
}

model SaleItem {
  id             String        @id @default(uuid())
  saleId         String
  professionalId String?
  productName    String
  quantity       Int           @default(1)
  unitPrice      Float
  totalPrice     Float
  commission     Float         @default(0)
  
  sale           Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
  professional   Professional? @relation(fields: [professionalId], references: [id])

  @@index([saleId])
}

model FinancialTransaction {
  id                String          @id @default(uuid())
  date              DateTime        @default(now())
  description       String
  category          String
  amount            Float
  grossAmount       Float?
  feeAmount         Float?
  netAmount         Float?
  cardFeePercent    Float?
  commissionAmount  Float?
  type              TransactionType
  status            String          @default("PENDING") // PENDING, PAID, CANCELED. Dados antigos podem conter COMPLETED.
  paymentMethod     String?
  notes             String?         @db.Text
  attachmentsJson   Json?
  paidAt            DateTime?
  canceledAt        DateTime?
  
  profit            Float?          // Lucro Real
  clinicProfit      Float?          // Alias
  operationalCost   Float?
  professionalValue Float?
  
  patientId         String?         // Relaciona ao paciente
  patient           Patient?        @relation(fields: [patientId], references: [id])

  saleId            String?
  sale              Sale?           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  installments      FinancialInstallment[]

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @default(now()) @updatedAt

  @@index([date])
  @@index([patientId])
  @@index([saleId])
}


model TreatmentCostItem {
  id          String   @id @default(uuid())
  treatmentId String
  name        String
  type        String   @default("Produto")
  quantity    Float    @default(1)
  unitCost    Float    @default(0)
  totalCost   Float    @default(0)
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  treatment   Treatment @relation(fields: [treatmentId], references: [id], onDelete: Cascade)

  @@index([treatmentId])
}

model TreatmentPlan {
  id              String   @id @default(uuid())
  patientId       String
  title           String
  objective       String?  @db.Text
  totalEstimated  Float    @default(0)
  status          String   @default("ACTIVE") // ACTIVE, FINISHED, CANCELED
  notes           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  steps           TreatmentPlanStep[]

  @@index([patientId])
  @@index([status])
}

model TreatmentPlanStep {
  id              String   @id @default(uuid())
  planId          String
  treatmentId     String?
  title           String
  priority        Int      @default(1)
  estimatedValue  Float    @default(0)
  status          String   @default("SUGGESTED") // SUGGESTED, ACCEPTED, REFUSED, POSTPONED, DONE
  plannedDate     DateTime?
  performedDate   DateTime?
  notes           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  plan            TreatmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  treatment       Treatment?    @relation(fields: [treatmentId], references: [id], onDelete: SetNull)

  @@index([planId])
  @@index([treatmentId])
  @@index([status])
}

model StructuredClinicalEvolution {
  id                 String   @id @default(uuid())
  patientId          String
  treatmentId        String?
  complaint          String?  @db.Text
  clinicalAssessment String?  @db.Text
  procedurePerformed String
  productUsed        String?
  batch              String?
  expiresAt          DateTime?
  bodyArea           String?
  quantity           String?
  intercurrences     String?  @db.Text
  guidance           String?  @db.Text
  recommendedReturn  DateTime?
  termSigned         Boolean  @default(false)
  photosTaken        Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @default(now()) @updatedAt

  patient            Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  treatment          Treatment? @relation(fields: [treatmentId], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([treatmentId])
  @@index([createdAt])
}

model PostProcedureTask {
  id             String   @id @default(uuid())
  patientId      String
  treatmentId    String?
  title          String
  message        String?  @db.Text
  dueDate        DateTime
  completedAt    DateTime?
  status         String   @default("PENDING") // PENDING, DONE, CANCELED
  channel        String   @default("WhatsApp")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  patient        Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  treatment      Treatment? @relation(fields: [treatmentId], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([dueDate])
  @@index([status])
}

model WhatsAppTemplate {
  id          String   @id @default(uuid())
  category    String
  title       String
  content     String   @db.Text
  defaultTime String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@index([category])
  @@index([isActive])
}

model EvaluationConversion {
  id             String   @id @default(uuid())
  patientId      String
  evaluationDate DateTime @default(now())
  proposedPlan   String?  @db.Text
  proposedValue  Float    @default(0)
  closedValue    Float    @default(0)
  status         String   @default("FOLLOW_UP") // CLOSED_SAME_DAY, CLOSED_LATER, FOLLOW_UP, LOST_EXPENSIVE, LOST_NO_INDICATION, LOST_OTHER
  lostReason     String?  @db.Text
  followUpDate   DateTime?
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  patient        Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([evaluationDate])
  @@index([status])
}

model BusinessGoal {
  id                String   @id @default(uuid())
  month             String   @unique
  startDate         DateTime?
  endDate           DateTime?
  revenueGoal       Float    @default(0)
  patientGoal       Int      @default(0)
  evaluationGoal    Int      @default(0)
  conversionGoal    Float    @default(0)
  averageTicketGoal Float    @default(0)
  notes             String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now()) @updatedAt

  @@index([month])
  @@index([startDate])
  @@index([endDate])
}

// -----------------------------------------
// DOCUMENTOS E CONFIGURAÇÕES
// -----------------------------------------

model PatientConsentDocument {
  id            String                @id @default(uuid())
  token         String                @unique
  patientId     String
  treatmentId   String
  title         String
  content       String
  status        ConsentDocumentStatus @default(PENDING)
  signedAt      DateTime?
  signatureName String?
  signatureIp   String?
  
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @default(now()) @updatedAt
  
  patient       Patient               @relation(fields: [patientId], references: [id])
  treatment     Treatment             @relation(fields: [treatmentId], references: [id])

  @@index([patientId])
  @@index([treatmentId])
}

model PatientContract {
  id             String         @id @default(uuid())
  token          String         @unique
  patientId      String
  title          String
  content        String
  total          Float          @default(0)
  status         ContractStatus @default(PENDING)
  itemsJson      Json
  
  signatureName  String?        // Nome de quem assinou
  signatureImage String?        @db.Text 
  signatureIp    String?
  signedAt       DateTime?
  
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @default(now()) @updatedAt
  patient        Patient        @relation(fields: [patientId], references: [id])

  @@index([patientId])
}

model Treatment {
  id                     String                   @id @default(uuid())
  name                   String                   @unique
  template               String                   // Template base do termo de consentimento
  standardPrice          Float                    @default(0)
  averageCost            Float                    @default(0)
  averageDurationMinutes Int                      @default(60)
  defaultReturnDays      Int?
  requiresTerm           Boolean                  @default(true)
  requiresPhotos         Boolean                  @default(false)
  requiresBatch          Boolean                  @default(false)
  postCareInstructions   String?                  @db.Text
  defaultWhatsAppMessage String?                  @db.Text
  isActive               Boolean                  @default(true)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @default(now()) @updatedAt
  
  documents              PatientConsentDocument[]
  sales                  Sale[]
  costItems              TreatmentCostItem[]
  planSteps              TreatmentPlanStep[]
  structuredEvolutions   StructuredClinicalEvolution[]
  postProcedureTasks     PostProcedureTask[]
}

model Professional {
  id         String     @id @default(uuid())
  name       String
  commission Float      @default(0.25)
  isActive   Boolean    @default(true)
  sales      Sale[]
  saleItems  SaleItem[]
}

model BlockedTime {
  id        String   @id @default(uuid())
  start     DateTime
  end       DateTime
  reason    String?
  createdAt DateTime @default(now())

  @@index([start, end])
}


model InventoryItem {
  id                   String   @id @default(uuid())
  product              String
  category             String?
  linkedProcedure      String?
  supplier             String?
  entryQuantity        Int      @default(0)
  quantity             Int      @default(0)
  entryDate            DateTime?
  batch                String?
  expiresAt            DateTime?
  minimumQuantity      Int      @default(1)
  unitValue            Float    @default(0)
  applicationMaterials      String?  @db.Text
  applicationMaterialsValue Float    @default(0)
  status               String   @default("DISPONIVEL")
  patientName          String?
  exitDate             DateTime?
  notes                String?  @db.Text
  createdAt            DateTime @default(now())
  updatedAt            DateTime @default(now()) @updatedAt
  movements            InventoryMovement[]

  @@index([product])
  @@index([category])
  @@index([linkedProcedure])
  @@index([status])
  @@index([patientName])
  @@index([expiresAt])
}

model FinancialInstallment {
  id                String   @id @default(uuid())
  transactionId     String?
  saleId            String?
  patientId         String?
  description       String
  installmentNumber Int      @default(1)
  totalInstallments Int      @default(1)
  amount            Float
  feeAmount         Float    @default(0)
  netAmount         Float?
  dueDate           DateTime
  paidAt            DateTime?
  canceledAt        DateTime?
  status            String   @default("PENDING")
  paymentMethod     String?
  notes             String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now()) @updatedAt

  transaction       FinancialTransaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  sale              Sale?                 @relation(fields: [saleId], references: [id], onDelete: Cascade)
  patient           Patient?              @relation(fields: [patientId], references: [id])

  @@index([transactionId])
  @@index([saleId])
  @@index([patientId])
  @@index([dueDate])
  @@index([status])
}

model MonthlyClosing {
  id               String   @id @default(uuid())
  month            String   @unique
  startDate        DateTime
  endDate          DateTime
  grossIncome      Float    @default(0)
  expenses         Float    @default(0)
  fees             Float    @default(0)
  commissions      Float    @default(0)
  netProfit        Float    @default(0)
  availableBalance Float    @default(0)
  averageTicket    Float    @default(0)
  topProcedure     String?
  status           String   @default("OPEN")
  closedAt         DateTime?
  notes            String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt

  @@index([startDate, endDate])
  @@index([status])
}

model InventoryMovement {
  id              String   @id @default(uuid())
  inventoryItemId String
  type            String
  quantity        Int
  unitValue       Float?
  totalValue      Float?
  reason          String?  @db.Text
  procedureName   String?
  patientId       String?
  date            DateTime @default(now())
  createdAt       DateTime @default(now())

  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  patient         Patient?      @relation(fields: [patientId], references: [id])

  @@index([inventoryItemId])
  @@index([patientId])
  @@index([date])
  @@index([type])
}

model PatientPhoto {
  id              String   @id @default(uuid())
  patientId       String
  title           String?
  procedureName   String?
  bodyArea        String?
  photoType       String   @default("CLINICAL")
  imageUrl        String   @db.Text
  takenAt         DateTime @default(now())
  imageAuthorized Boolean  @default(false)
  notes           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([takenAt])
  @@index([imageAuthorized])
}

model AuditLog {
  id          String   @id @default(uuid())
  action      String
  entity      String
  entityId    String?
  description String?  @db.Text
  userName    String?
  beforeJson  Json?
  afterJson   Json?
  contextJson Json?
  createdAt   DateTime @default(now())

  @@index([entity])
  @@index([createdAt])
}

model BackupHistory {
  id        String   @id @default(uuid())
  type      String   @default("MANUAL")
  target    String   @default("LOCAL")
  status    String   @default("SUCCESS")
  sizeLabel String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// -----------------------------------------
// ENUMS (PADRONIZAÇÃO)
// -----------------------------------------

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  NO_SHOW
  RESCHEDULED
  CANCELED
  RETURN
  FIT_IN
}

enum PaymentStatus {
  PENDING
  PAID
  CANCELED
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum Room {
  A
  B
}

enum ConsentDocumentStatus {
  PENDING
  SIGNED
  CANCELED
}

enum ContractStatus {
  PENDING
  SIGNED
  CANCELED
}

enum ContractPaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  PIX
  CASH
  BANK_SLIP
  BANK_TRANSFER
  OTHER
}

enum ClinicalEvolutionPlanStatus {
  ACTIVE
  FINISHED
  CANCELED
}